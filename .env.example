# TaskFuchs — Supabase Konfiguration
# Werte findest du im Supabase Dashboard unter: Settings → API

# Supabase Projekt-URL (z.B. https://abcdefghij.supabase.co)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon/Public Key (sicher fuer Client-seitigen Zugriff, RLS schuetzt die Daten)
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
